# Porta em que o servidor vai rodar
PORT=3000

# Chave secreta usada para assinar tokens JWT (troque em produção!)
JWT_SECRET=troque-esta-chave-por-um-valor-seguro-e-aleatorio

# ─── Banco de dados (Turso / libSQL) ───
# Em produção (Vercel), defina estas variáveis no dashboard do Vercel:
#   Settings → Environment Variables
# Crie um banco gratuito em https://turso.tech e gere um auth token.
TURSO_DATABASE_URL=libsql://seu-banco.turso.io
TURSO_AUTH_TOKEN=

# Fallback local: se TURSO_DATABASE_URL não estiver definida, o app usa
# um arquivo SQLite local (file:./data/petcare.db). Ideal para dev.

# ─── Assistente IA do dashboard ───
# Chave da Claude API (Anthropic) — usada pelo Assistente IA do dashboard
# para responder dúvidas sobre o sistema e gerar insights financeiros.
# Se não estiver configurada, o assistente usa um fallback baseado em regras
# que funciona offline (útil em dev). Obtenha sua chave em:
#   https://console.anthropic.com/
ANTHROPIC_API_KEY=
# Opcional: modelo Claude usado pelo assistente (default: claude-haiku-4-5-20251001)
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Ambiente (development | production)
NODE_ENV=development
