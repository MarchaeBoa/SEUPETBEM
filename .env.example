# Porta em que o servidor vai rodar (local only — ignorado no Vercel)
PORT=3000

# Chave secreta usada para assinar tokens JWT (troque em produção!)
JWT_SECRET=troque-esta-chave-por-um-valor-seguro-e-aleatorio

# Connection string do Postgres (Neon). Pegue em https://console.neon.tech
# Formato: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/neondb?sslmode=require

# Ambiente (development | production)
NODE_ENV=development
